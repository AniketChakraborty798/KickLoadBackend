# Copy these into `backend/.env` on the EC2 host (do not commit secrets).
#
# InfluxDB (container init)
INFLUXDB_USERNAME=kickload
INFLUXDB_PASSWORD=change-me
INFLUXDB_ORG=kickload
INFLUXDB_BUCKET=kickload
INFLUX_TOKEN=change-me-long-token
#
# Backend reads these for writes/queries
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=kickload
INFLUX_BUCKET=kickload
INFLUX_TOKEN=change-me-long-token
#
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# Optional: expose through nginx-proxy (docker-compose.yml only)
GRAFANA_VIRTUAL_HOST=grafana.neeyatai.com
GRAFANA_CERT_NAME=grafana.neeyatai.com
# Optional: local-only access port on EC2 (SSH tunnel recommended)
GRAFANA_LOCAL_PORT=3001

# PDF reports: server-side panel rendering (optional)
# Base URL used by the backend PDF generator to call Grafana's `/render/d-solo/...` endpoint.
# If you run Grafana with subpath `/grafana`, include it here (recommended with current compose).
GRAFANA_RENDER_BASE_URL=http://grafana:3000/grafana
#
# If anonymous Grafana access is disabled, create a Grafana Service Account token and set it here.
# (Viewer role is sufficient for rendering panels.)
GRAFANA_API_TOKEN=

